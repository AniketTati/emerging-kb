# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# uv — keep the lockfile committed for reproducible builds (build_tracker §3).
# (No entry here; uv.lock IS tracked.)

# Env / secrets
.env
.env.local
*.secret

# Docker compose local overrides (per-developer, never committed)
docker-compose.override.yml
docker-compose.override.yaml

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Docker volumes (when bind-mounted locally)
.volumes/
data/
minio-data/
pg-data/

# Logs
*.log
logs/

# Eval outputs (we'll regenerate)
eval/outputs/

# Local Claude config (keep private)
.claude/

# Original problem brief — kept locally, never tracked.
# The public-friendly version is at docs/problem_statement.md.
docs/Build a Knowledge Base Service.pdf

# Prototype QA artifacts — regenerable, don't bloat the repo
prototype/node_modules/
prototype/package-lock.json
prototype/qa/screens/
prototype/qa/reports/

# Local demo-corpus testing artifacts — scratch generated during
# ingest/validation runs, not part of the canonical corpus. The actual
# demo docs + build.py/ingest.py loaders ARE tracked; only these
# workspace artifacts get ignored.
demo-corpus/domains/
demo-corpus/workspaces/
demo-corpus/entities.yaml
demo-corpus/validate.py
