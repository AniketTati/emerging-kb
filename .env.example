# --------------------------------------------------------------------------
# Environment template. Copy to `.env` and edit. `.env` is gitignored.
# Phase 0 through Phase 3b-bis. Required for local dev + docker-compose.
# --------------------------------------------------------------------------

# Postgres (used by docker-compose to provision the `db` service).
KB_POSTGRES_USER=kb
KB_POSTGRES_PASSWORD=kb-dev-password
KB_POSTGRES_DB=kb
KB_POSTGRES_HOST=db
KB_POSTGRES_PORT=5432

# Password set on the `kb_app` non-superuser role at first migration.
# `kb_app` is what the API + worker connect as; RLS applies to it.
KB_APP_PASSWORD=kb-app-dev-password

# MinIO (object store).
KB_MINIO_ENDPOINT=minio:9000
KB_MINIO_ACCESS_KEY=kb-minio-dev
KB_MINIO_SECRET_KEY=kb-minio-dev-secret
KB_MINIO_BUCKET=kb
KB_MINIO_SECURE=false

# App.
KB_LOG_LEVEL=INFO
KB_LOG_FORMAT=json

# Default workspace UUID — Phase 0 hardcodes single-tenant operation.
# RLS policies still apply; later phases resolve workspace_id from auth.
KB_DEFAULT_WORKSPACE_ID=00000000-0000-0000-0000-000000000000

# --------------------------------------------------------------------------
# External LLM / API keys
# --------------------------------------------------------------------------
# All optional — the pipeline degrades gracefully when keys are unset
# (see fallbacks below). For a full-fidelity demo, set at minimum
# KB_GEMINI_API_KEY (embeddings + contextual retrieval default path).

# Phase 3c — Gemini Embedding 001. Unset → DeterministicMockEmbedder
# (deterministic but semantically-meaningless vectors; CI-only).
KB_GEMINI_API_KEY=

# Phase 3b / 3b-bis — Anthropic Claude. Unset → AnthropicContextualizer
# unavailable (factory falls through to the next adapter).
KB_ANTHROPIC_API_KEY=

# Phase 1c (optional) — Mistral OCR 3 for scanned PDFs. Unset → MistralOCR
# parser short-circuits; scanned PDFs fail. Digital PDFs work without it.
KB_MISTRAL_API_KEY=

# --------------------------------------------------------------------------
# Adapter selection (Phase 3b-bis §5.8.1)
# --------------------------------------------------------------------------
# Contextualizer adapter. Values: gemini | anthropic | identity | auto.
# `auto` (default) probes: KB_GEMINI_API_KEY → KB_ANTHROPIC_API_KEY →
# Identity. Gemini-first matches the "single Gemini key" demo story.
# Explicit `gemini`/`anthropic` without the matching key raises ValueError
# at startup (loud-fail beats silent-fallback for misconfigs).
KB_CONTEXTUALIZER=auto

# Optional model overrides (both adapters honour KB_CONTEXTUAL_MODEL;
# leave blank to use each adapter's default).
#   AnthropicContextualizer default: claude-opus-4-7
#   GeminiContextualizer default:    gemini-2.5-flash
# KB_CONTEXTUAL_MODEL=

# Phase 3c — embedding model override. Default: gemini-embedding-001.
# KB_EMBEDDING_MODEL=

# --------------------------------------------------------------------------
# Parser strategy + OCR (Phase 2c §5.6.1)
# --------------------------------------------------------------------------
# Parser dispatch strategy for PDFs. Values:
#   auto           — default. Pre-flight text-layer sniff:
#                      avg chars/page >= 50 → Docling (digital)
#                      else                 → Gemini OCR (scanned)
#                    Soft Docling fallback if KB_GEMINI_API_KEY is unset.
#   docling_first  — always Docling; worker escalates to Gemini on bad quality
#                    (empty / printable_ratio<0.7 / hybrid per-page).
#   gemini_first   — always Gemini OCR (opportunistic; soft fallback if no key).
#   gemini_only    — Gemini OCR only; missing key → parsing→failed (loud fail).
# Per-call override: POST /files?parser=<auto|docling|gemini>.
KB_PARSER_STRATEGY=auto

# Optional sniff/render/OCR tuning (leave blank for defaults).
#   KB_PDF_TEXT_LAYER_THRESHOLD=50          # avg chars/page floor for sniff
#   KB_PDF_TEXT_LAYER_MAX_PAGES_SAMPLED=10  # cap sniff cost on huge PDFs
#   KB_OCR_MODEL=gemini-2.5-flash           # override Gemini VLM model
#   KB_OCR_CONCURRENCY=4                    # asyncio.Semaphore per-page cap
#   KB_OCR_RENDER_DPI=150                   # pypdfium2 page render DPI

# --------------------------------------------------------------------------
# Phase 3a — chunker tuning (optional)
# --------------------------------------------------------------------------
# Defaults from build_tracker §5.7 #1. Tests override to ~200 tokens for
# fast deterministic multi-chunk fixtures.
# KB_CHUNK_TOKENS=2500
# KB_CHUNK_OVERLAP_TOKENS=250
